{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/home", "destination": "/index.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/mods", "destination": "/mods.html" },
    { "source": "/apply", "destination": "/apply.html" },
    { "source": "/download", "destination": "/download.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/patchnotes", "destination": "/patchnotes.html" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/[...slug].js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PATCH,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}